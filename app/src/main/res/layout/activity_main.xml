<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏥 SehatYuk"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kalkulator BMI &amp; BMR"
            android:textSize="14sp"
            android:textColor="#5F6368"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Card Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Diri"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_marginBottom="16dp" />

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Masukkan nama Anda"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Berat Badan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berat Badan (kg)"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etBeratBadan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh: 65"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Tinggi Badan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tinggi Badan (cm)"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etTinggiBadan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh: 170"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Umur -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Umur (tahun)"
                android:textSize="12sp"
                android:textColor="#5F6368"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etUmur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh: 22"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnHitungBMI"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hitung BMI"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A73E8"
                android:layout_marginEnd="8dp"
                android:padding="14dp"
                android:textStyle="bold"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnHitungBMR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hitung BMR"
                android:textColor="#FFFFFF"
                android:backgroundTint="#34A853"
                android:layout_marginStart="8dp"
                android:padding="14dp"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Hasil -->
        <LinearLayout
            android:id="@+id/layoutHasil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:visibility="gone"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Hasil Perhitungan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvHasil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#3C4043"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>